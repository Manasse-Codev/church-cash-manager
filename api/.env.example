# EgliseFinance API — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# ── Base de données ───────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eglise_finance?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec: openssl rand -base64 64
JWT_SECRET="changez-moi-par-une-clef-tres-longue-et-aleatoire-min-256bits"
JWT_EXPIRES_IN="24h"

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Séparer plusieurs origines par une virgule
CORS_ORIGIN="http://localhost:3000,http://localhost:5173"

# ── Rate limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
